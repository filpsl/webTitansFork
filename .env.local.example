# NUNCA preencha valores reais neste arquivo — ele é commitado.
# Copie para .env.local (já está no .gitignore) e edite lá:
#   cp .env.local.example .env.local
#
# Em produção (Vercel), estas variáveis vivem em
# Project Settings → Environment Variables, não neste arquivo.

# Cliente (NEXT_PUBLIC_*: empacotados no bundle do navegador).
# A anon key + URL pública é OK expor — a RLS do Supabase protege os dados.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Link de convite do grupo de ajuda dos CLIENTES no Telegram (grupo separado do
# chat de notificações da equipe, TELEGRAM_CHAT_ID). Opcional — sem ela o botão
# do Telegram não aparece no kiosk. Convite público por natureza, então pode ser
# NEXT_PUBLIC_ (qualquer um com o QR entra no grupo).
NEXT_PUBLIC_TELEGRAM_HELP_INVITE_URL=

# Servidor (consumidas apenas pelos Route Handlers / libs em src/lib/server/*).
# REGRA DE SEGURANÇA: segredos de servidor NUNCA levam o prefixo NEXT_PUBLIC_ —
# o prefixo os empacotaria no bundle do cliente, vazando-os.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Notificação dos chamados de ajuda do kiosk (/api/kiosk/help) via Telegram.
# Opcionais: sem elas os chamados só ficam registrados na tabela chamados_ajuda.
# Crie um bot com o @BotFather (token) e adicione-o ao grupo/canal da equipe;
# TELEGRAM_CHAT_ID é o id do chat (ex.: -1001234567890 para grupos).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook de ENTRADA do bot do Telegram (/api/telegram/webhook) — comandos
# administrativos de reimpressão (/reimprimir, /gerar_codigo).
# TELEGRAM_ADMIN_IDS: allowlist de Telegram user IDs autorizados a usar os
# comandos, separados por vírgula (ex.: 111111111,222222222). Autorização é
# SEMPRE por essa lista, nunca por "estar no grupo" — pegue o próprio ID em
# conversa com @userinfobot.
# TELEGRAM_WEBHOOK_SECRET: o secret_token configurado no setWebhook; o
# webhook rejeita qualquer request sem o header
# X-Telegram-Bot-Api-Secret-Token correspondente. Gere com, por exemplo,
# `openssl rand -hex 32`.
TELEGRAM_ADMIN_IDS=
TELEGRAM_WEBHOOK_SECRET=

# URL canônica de produção, usada como notification_url do webhook do Mercado Pago.
# Fixar o domínio evita que um deploy de preview efêmero (*.vercel.app) registre
# uma notification_url que o Mercado Pago não conseguiria reconfirmar.
# Em dev/Docker local pode ficar vazia (o handler cai nos headers x-forwarded-*).
PUBLIC_BASE_URL=https://www.roboticstitans.com.br
